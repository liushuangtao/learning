<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.base.ciscarbonbase.button.dao.mapper.CisSysMenuButtonMapper">

	<!-- 通用查询映射结果 -->
	<resultMap id="BaseResultMap" type="com.base.ciscarbonbase.button.dao.entity.CisSysMenuButtonEntity">
		<result column="id" property="id" />
		<result column="version" property="version" />
		<result column="create_user_id" property="createUserId" />
		<result column="create_time" property="createTime" />
		<result column="update_user_id" property="updateUserId" />
		<result column="update_time" property="updateTime" />
		<result column="menu_code" property="menuCode" />
		<result column="button_code" property="buttonCode" />
		<result column="create_user_name" property="createUserName" />
		<result column="update_user_name" property="updateUserName" />
	</resultMap>

	<select id="queryPermissionButton" resultMap="BaseResultMap">
		select distinct menu_code, button_code from cis_sys_menu_role_button
		<where>
			menu_code = #{menuCode}
			<if test="roleCodes != null and roleCodes.size > 0">
				and role_code in
				<foreach collection="roleCodes" item="roleCode" open="(" separator="," close=")">
					#{roleCode}
				</foreach>
			</if>
		</where>
	</select>

</mapper>
